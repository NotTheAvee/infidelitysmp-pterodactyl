{
  "name": "Pterodactyl Codespace Auto Starter",

  "forwardPorts": [8000, 8080],

  "portsAttributes": {
    "8000": {
      "label": "Pterodactyl Panel",
      "onAutoForward": "openBrowser"
    },
    "8080": {
      "label": "Pterodactyl Wings",
      "onAutoForward": "silent"
    }
  },

  "postStartCommand": "bash /workspaces/minecraftpufferpanel/.devcontainer/start-pterodactyl.sh",

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
